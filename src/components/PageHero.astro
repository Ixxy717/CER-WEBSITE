---
interface Props {
  title: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---

<section class="bg-charcoal text-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-3">{title}</h1>
    {subtitle && (
      <p class="text-white/65 text-lg max-w-2xl">{subtitle}</p>
    )}
  </div>
</section>

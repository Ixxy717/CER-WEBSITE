---

<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
  {items.map(item => (
    <div class="flex items-center gap-3 bg-card rounded-lg px-4 py-3 shadow-sm border border-black/5">
      <span class="text-brand-green shrink-0 w-5 h-5" set:html={item.icon} />
      <span class="text-sm font-medium text-charcoal leading-tight">
        {item.label}
        {item.note && (
          <span class="block text-xs text-brand-green font-normal">{item.note}</span>
        )}
      </span>
    </div>
  ))}
</div>

{showNote && (
  <p class="mt-4 text-sm text-charcoal/60 text-center">
    Not sure if we take it?{' '}
    <a href="/contact" class="text-brand-green hover:underline font-medium">Give us a call</a>
    {' '}— if it plugs in or runs on a battery, chances are we do.
  </p>
)}

---
import BaseLayout from '../layouts/BaseLayout.astro';
import AcceptedItems from '../components/AcceptedItems.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
---

<BaseLayout
  title="Home"
  description="Chagrin Electronic Recycling — free electronics drop-off in Chagrin Falls, OH. Free pickup for 12+ items. TVs, computers, phones, and more."
>

  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="relative text-white overflow-hidden min-h-[480px] md:min-h-[560px] flex items-center">
    <!-- Banner image -->
    <img
      src="/assets/banner.png"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover object-center"
    />
    <!-- Dark overlay so text stays readable -->
    <div class="absolute inset-0 bg-charcoal/75"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 w-full">
      <div class="max-w-2xl">
        <h1 class="text-4xl sm:text-5xl font-bold leading-tight tracking-tight mb-5">
          Drop off your electronics.<br />
          <span class="text-brand-green">We handle the rest.</span>
        </h1>
        <p class="text-lg text-white/75 mb-8 leading-relaxed">
          Community electronics recycling in Chagrin Falls, OH.
          Free drop-off, no appointment needed.
          Free pickup for 12&nbsp;or more items.
          Responsible recycling for what remains.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="/contact"
            class="inline-block bg-brand-green text-charcoal font-semibold px-6 py-3 rounded-lg hover:brightness-110 transition-all"
          >
            Schedule a Pickup
          </a>
          <a
            href="#accepted-items"
            class="inline-block bg-white/10 text-white font-semibold px-6 py-3 rounded-lg hover:bg-white/20 transition-all border border-white/20"
          >
            See What We Accept
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Info bar ──────────────────────────────────────────── -->

  <section class="bg-surface text-white/80 border-y border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex flex-col sm:flex-row flex-wrap items-start sm:items-center gap-4 sm:gap-8 text-sm">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-green shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
          </svg>
          <span>10140 Gottschalk Pkwy, Chagrin Falls, OH 44022</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-green shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
          </svg>
          <a href="tel:+14406019166" class="hover:text-brand-green transition-colors">(440) 601-9166</a>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-green shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          <span class="text-brand-green font-medium">Free drop-off — no appointment needed</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Accepted Items ────────────────────────────────────── -->
  <section id="accepted-items" class="bg-section-light py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-charcoal mb-3">What We Accept</h2>
        <p class="text-charcoal/60 max-w-xl mx-auto">
          We take most consumer and business electronics. Bring them in as-is — no need to wipe or prep anything.
        </p>
      </div>
      <AcceptedItems />
    </div>
  </section>

  <!-- ── How It Works ──────────────────────────────────────── -->
  <section class="bg-section-white py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-charcoal mb-3">How It Works</h2>
        <p class="text-charcoal/60">Simple as it gets.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
        <!-- Step 1 -->
        <div class="flex flex-col items-center text-center gap-4">
          <div class="w-14 h-14 rounded-full bg-brand-green/15 flex items-center justify-center">
            <span class="text-2xl font-bold text-brand-green">1</span>
          </div>
          <h3 class="font-semibold text-lg text-charcoal">Bring it in</h3>
          <p class="text-charcoal/60 text-sm leading-relaxed">
            Drop off your old electronics at our facility on Gottschalk Pkwy.
            No appointment, no fuss. Or we'll come to you — free pickup for 12 or more items.
          </p>
        </div>
        <!-- Step 2 -->
        <div class="flex flex-col items-center text-center gap-4">
          <div class="w-14 h-14 rounded-full bg-brand-green/15 flex items-center justify-center">
            <span class="text-2xl font-bold text-brand-green">2</span>
          </div>
          <h3 class="font-semibold text-lg text-charcoal">We sort it</h3>
          <p class="text-charcoal/60 text-sm leading-relaxed">
            Everything is sorted by hand. Items that still have life in them
            get repaired, refurbished, or passed along for reuse.
          </p>
        </div>
        <!-- Step 3 -->
        <div class="flex flex-col items-center text-center gap-4">
          <div class="w-14 h-14 rounded-full bg-brand-green/15 flex items-center justify-center">
            <span class="text-2xl font-bold text-brand-green">3</span>
          </div>
          <h3 class="font-semibold text-lg text-charcoal">Responsibly recycled</h3>
          <p class="text-charcoal/60 text-sm leading-relaxed">
            Whatever can't be reused goes to a certified end-of-life facility
            for proper material recovery — not the landfill.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── TV + Corporate callouts ──────────────────────────── -->
  <section class="bg-section-warm py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <!-- TV callout -->
        <div class="bg-card rounded-xl p-7 border border-black/5 shadow-sm flex flex-col gap-4">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-brand-green/15 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-brand-green" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 20.25h12M3.75 6.75h16.5M3.75 6.75A2.25 2.25 0 0 1 6 4.5h12a2.25 2.25 0 0 1 2.25 2.25v9a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 15.75v-9Z" />
              </svg>
            </div>
            <h3 class="font-bold text-lg text-charcoal">Recycling a TV?</h3>
          </div>
          <p class="text-charcoal/65 text-sm leading-relaxed">
            TVs contain mercury and other hazardous materials that require special handling.
            We charge <strong class="text-charcoal">$1 per inch</strong> of diagonal screen size
            to cover proper disposal. Pay online before you drop off.
          </p>
          <a
            href="/tv-recycling"
            class="mt-auto inline-flex items-center gap-1.5 text-brand-green font-semibold text-sm hover:underline"
          >
            Calculate your fee & pay online
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>

        <!-- Corporate callout -->
        <div class="bg-card rounded-xl p-7 border border-black/5 shadow-sm flex flex-col gap-4">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-brand-green/15 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-brand-green" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
              </svg>
            </div>
            <h3 class="font-bold text-lg text-charcoal">Upgrading your office?</h3>
          </div>
          <p class="text-charcoal/65 text-sm leading-relaxed">
            We handle corporate IT asset recovery, secure hard drive destruction,
            and business equipment cleanouts. We'll coordinate pickup and make
            sure your data and devices are handled properly.
          </p>
          <a
            href="https://scarce-resources.com"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-auto inline-flex items-center gap-1.5 text-brand-green font-semibold text-sm hover:underline"
          >
            Corporate services
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Mission ───────────────────────────────────────────── -->
  <section class="bg-charcoal text-white py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">

        <!-- E-waste image -->
        <div class="order-2 md:order-1">
          <img
            src="/assets/ugly-ewaste.png"
            alt="Pile of discarded electronics and e-waste"
            class="rounded-xl w-full h-64 md:h-80 object-cover object-center"
          />
        </div>

        <!-- Text -->
        <div class="order-1 md:order-2">
          <p class="text-brand-green font-semibold text-sm uppercase tracking-widest mb-4">Our Mission</p>
          <h2 class="text-3xl font-bold mb-5">Keeping Northeast Ohio's electronics out of the landfill</h2>
          <p class="text-white/70 leading-relaxed mb-6">
            Each year, 50 million tons of broken and obsolete electronics end up in landfills —
            accounting for up to 70% of all toxic waste. We're a local operation with a simple goal:
            make it easy for our community to do the right thing with their old devices.
            Drop it off, and we'll take care of the rest.
          </p>
          <a
            href="/about"
            class="inline-block text-brand-green font-semibold hover:underline text-sm"
          >
            More about how we operate →
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Instagram Feed ────────────────────────────────── -->
  <InstagramFeed />

</BaseLayout>

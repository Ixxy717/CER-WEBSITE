---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout
  title="About"
  description="Learn about Chagrin Electronic Recycling — our mission, how we handle your electronics, and our connection to the Northeast Ohio community."
>

  <PageHero
    title="About Us"
    subtitle="A local operation with a simple mission: make it easy to do the right thing with old electronics."
  />

  <!-- ── Mission ───────────────────────────────────────────── -->
  <section class="bg-section-white py-14 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-brand-green font-semibold text-sm uppercase tracking-widest mb-4">Our Mission</p>
        <h2 class="text-3xl font-bold text-charcoal mb-6 leading-snug">
          Keep electronics out of Northeast Ohio's landfills
        </h2>
        <div class="flex flex-col gap-4 text-charcoal/70 leading-relaxed">
          <p>
            Each year, 50 million tons of broken and obsolete electronics end up in landfills worldwide —
            making up as much as 70% of all toxic waste. Old phones, computers, TVs, and tablets
            contain lead, mercury, cadmium, and other materials that don't belong in the ground.
          </p>
          <p>
            Chagrin Electronic Recycling exists to give Northeast Ohio residents and businesses a
            better option. We make drop-off free, convenient, and available without an appointment.
            For larger loads, we come to you. There's no excuse to throw this stuff in the trash
            when there's an easy alternative right here in Chagrin Falls.
          </p>
          <p>
            We're not a big national chain. We're a local operation that knows this community and
            cares about what happens to its waste. Every item you drop off here stays out of a landfill.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── What happens to your electronics ─────────────────── -->
  <section class="bg-section-light py-14 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <h2 class="text-2xl font-bold text-charcoal mb-3">What Happens to Your Electronics</h2>
        <p class="text-charcoal/60 max-w-xl">
          Nothing goes straight to a shredder. Every item gets looked at first.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <div class="bg-card rounded-xl p-7 border border-black/5 shadow-sm flex flex-col gap-4">
          <div class="w-11 h-11 rounded-lg bg-brand-green/15 flex items-center justify-center">
            <svg class="w-5 h-5 text-brand-green" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 0 1 0 3.75H5.625a1.875 1.875 0 0 1 0-3.75Z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-charcoal mb-2">Sorted by Hand</h3>
            <p class="text-charcoal/65 text-sm leading-relaxed">
              When your items arrive, they're sorted individually. We assess condition,
              identify what's reusable, and separate materials that need special handling
              (like TV panels or batteries).
            </p>
          </div>
        </div>

        <div class="bg-card rounded-xl p-7 border border-black/5 shadow-sm flex flex-col gap-4">
          <div class="w-11 h-11 rounded-lg bg-brand-green/15 flex items-center justify-center">
            <svg class="w-5 h-5 text-brand-green" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-charcoal mb-2">Reused or Refurbished</h3>
            <p class="text-charcoal/65 text-sm leading-relaxed">
              Anything with life left in it gets a second chance. Working parts are harvested
              for repair. Functional devices get refurbished or passed along to someone who
              can use them. Reuse is always the first priority.
            </p>
          </div>
        </div>

        <div class="bg-card rounded-xl p-7 border border-black/5 shadow-sm flex flex-col gap-4">
          <div class="w-11 h-11 rounded-lg bg-brand-green/15 flex items-center justify-center">
            <svg class="w-5 h-5 text-brand-green" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253M3 12c0 .778.099 1.533.284 2.253" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-charcoal mb-2">Responsibly Recycled</h3>
            <p class="text-charcoal/65 text-sm leading-relaxed">
              What can't be reused goes to a certified end-of-life recycling facility for
              proper material recovery. Metals, plastics, and hazardous components are
              processed correctly — not dumped.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Northeast Ohio ─────────────────────────────────────── -->
  <section class="bg-section-white py-14 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">

        <div>
          <h2 class="text-2xl font-bold text-charcoal mb-4">Rooted in Northeast Ohio</h2>
          <div class="flex flex-col gap-4 text-charcoal/70 leading-relaxed text-sm">
            <p>
              We're based in Chagrin Falls and focused on serving the surrounding Northeast Ohio
              community — residents, small businesses, schools, and anyone else who needs a
              responsible place to bring their old electronics.
            </p>
            <p>
              Drop-off is always free. No membership, no registration, no forms to fill out.
              Pull up, drop off, done. If you have a lot to get rid of, call us and
              we'll schedule a free pickup.
            </p>
            <p>
              This is community work. The easier we make it, the less e-waste ends up in the
              wrong place. That's the whole idea.
            </p>
          </div>
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href="/residential"
              class="inline-block bg-brand-green text-charcoal font-semibold text-sm px-5 py-2.5 rounded-lg hover:brightness-110 transition-all"
            >
              Drop-Off & Pickup Info
            </a>
            <a
              href="/contact"
              class="inline-block bg-charcoal text-white font-semibold text-sm px-5 py-2.5 rounded-lg hover:bg-surface transition-all"
            >
              Get in Touch
            </a>
          </div>
        </div>

        <div class="flex flex-col gap-4">
          <div class="bg-section-light rounded-xl p-6 border border-black/5">
            <div class="flex items-center gap-3 mb-3">
              <svg class="w-5 h-5 text-brand-green shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
              </svg>
              <span class="font-semibold text-charcoal text-sm">Our location</span>
            </div>
            <p class="text-charcoal/65 text-sm">
              10140 Gottschalk Pkwy<br />
              Chagrin Falls, OH 44022
            </p>
          </div>
          <div class="bg-section-light rounded-xl p-6 border border-black/5">
            <div class="flex items-center gap-3 mb-3">
              <svg class="w-5 h-5 text-brand-green shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
              </svg>
              <span class="font-semibold text-charcoal text-sm">Call us</span>
            </div>
            <div class="flex flex-col gap-1">
              <a href="tel:+14406019166" class="text-charcoal/65 text-sm hover:text-brand-green transition-colors">(440) 601-9166</a>
              <a href="tel:+14406014153" class="text-charcoal/65 text-sm hover:text-brand-green transition-colors">(440) 601-4153</a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Sister company SRC ─────────────────────────────────── -->
  <section class="bg-charcoal text-white py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-5">
        <div class="max-w-xl">
          <p class="text-brand-green font-semibold text-sm uppercase tracking-widest mb-2">Sister Company</p>
          <h3 class="font-bold text-lg mb-2">Need bulk or business-scale electronics recovery?</h3>
          <p class="text-white/60 text-sm leading-relaxed">
            Chagrin Electronic Recycling focuses on residential and community drop-off.
            For large-volume IT asset recovery, ITAD, and B2B electronics, our sister company
            <strong class="text-white">Scarce Resources Company Inc.</strong> handles that side of the business.
            Same ownership, different scale.
          </p>
        </div>
        <a
          href="https://scarce-resources.com"
          target="_blank"
          rel="noopener noreferrer"
          class="shrink-0 inline-block bg-brand-green text-charcoal font-semibold text-sm px-5 py-2.5 rounded-lg hover:brightness-110 transition-all"
        >
          Visit Scarce Resources →
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

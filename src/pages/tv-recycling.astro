---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout
  title="TV Recycling"
  description="Recycle your TV in Chagrin Falls, OH. $1 per diagonal inch. Cash only at drop-off."
>

  <PageHero
    title="TV Recycling"
    subtitle="$1 per diagonal inch. Cash only — pay when you drop off."
  />

  <!-- ── Why TVs cost money ──────────────────────────────── -->
  <section class="bg-section-white py-14 md:py-18">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">

        <div>
          <h2 class="text-2xl font-bold text-charcoal mb-4">Why is there a fee for TVs?</h2>
          <div class="flex flex-col gap-4 text-charcoal/70 leading-relaxed text-sm">
            <p>
              Most electronics we accept are completely free to drop off. TVs are the exception,
              and here's why: older televisions — especially CRTs and many flat panels — contain
              <strong class="text-charcoal">mercury, lead, and other hazardous materials</strong>
              that require special handling to dispose of safely.
            </p>
            <p>
              Standard recycling facilities can't process them the same way. Proper TV disposal
              requires certified hazardous material handling, which carries a real cost. Rather than
              turn TVs away (which leads to illegal dumping and landfill contamination), we charge
              a modest fee to cover that process.
            </p>
            <p>
              The fee is <strong class="text-charcoal">$1 per diagonal inch</strong> of screen size.
              A 40-inch TV is $40. A 55-inch TV is $55. No hidden charges, no surprises.
            </p>
          </div>

          <!-- Cash only callout -->
          <div class="mt-6 bg-brand-green/10 border border-brand-green/25 rounded-xl p-5 text-sm">
            <p class="font-semibold text-charcoal mb-1">Cash only — collected at drop-off</p>
            <p class="text-charcoal/65">
              We accept cash payment when you arrive. No need to pay in advance —
              just know your TV's screen size and bring the right amount.
              Not sure of the size? Check the sticker on the back of your TV or look up the model number.
            </p>
          </div>

          <div class="mt-4 bg-section-light border border-black/5 rounded-xl p-5 text-sm text-charcoal/65">
            <p class="font-semibold text-charcoal mb-1">All types accepted</p>
            <p>Flat panel (LCD, LED, OLED, Plasma), CRT tube TVs, projector TVs, and monitors. All sizes.</p>
          </div>
        </div>

        <!-- Pricing table -->
        <div>
          <div class="bg-section-light rounded-xl p-6 border border-black/5">
            <h3 class="font-bold text-charcoal mb-1">Pricing Reference</h3>
            <p class="text-xs text-charcoal/45 mb-4">$1.00 per diagonal inch of screen size</p>
            <div class="flex flex-col gap-3 text-sm">
              {[
                ['24"', '$24'],
                ['28"', '$28'],
                ['32"', '$32'],
                ['36"', '$36'],
                ['43"', '$43'],
                ['46"', '$46'],
                ['48"', '$48'],
                ['50"', '$50'],
                ['55"', '$55'],
                ['65"', '$65'],
                ['70"', '$70'],
                ['75"', '$75'],
                ['80"', '$80'],
              ].map(([size, fee]) => (
                <div class="flex items-center justify-between border-b border-black/5 pb-3 last:border-0 last:pb-0">
                  <span class="text-charcoal/70">{size} TV</span>
                  <span class="font-semibold text-charcoal">{fee}</span>
                </div>
              ))}
            </div>
            <p class="text-xs text-charcoal/40 mt-4 pt-3 border-t border-black/5">
              Don't see your size? The math is simple — just multiply your screen's diagonal inches by $1.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── How it works ───────────────────────────────────── -->
  <section class="bg-charcoal text-white py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-xl font-bold mb-6">How It Works</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="flex gap-3">
          <div class="w-8 h-8 rounded-full bg-brand-green/20 flex items-center justify-center shrink-0">
            <span class="text-brand-green font-bold text-sm">1</span>
          </div>
          <div>
            <p class="font-semibold text-sm mb-1">Check your TV's size</p>
            <p class="text-white/60 text-sm">Look at the sticker on the back or look up the model. The diagonal inch measurement is the screen size.</p>
          </div>
        </div>
        <div class="flex gap-3">
          <div class="w-8 h-8 rounded-full bg-brand-green/20 flex items-center justify-center shrink-0">
            <span class="text-brand-green font-bold text-sm">2</span>
          </div>
          <div>
            <p class="font-semibold text-sm mb-1">Bring cash & drop off</p>
            <p class="text-white/60 text-sm">Head to our facility on Gottschalk Pkwy. No appointment needed. Pay $1 per inch in cash when you arrive.</p>
          </div>
        </div>
        <div class="flex gap-3">
          <div class="w-8 h-8 rounded-full bg-brand-green/20 flex items-center justify-center shrink-0">
            <span class="text-brand-green font-bold text-sm">3</span>
          </div>
          <div>
            <p class="font-semibold text-sm mb-1">We handle the rest</p>
            <p class="text-white/60 text-sm">Your TV gets properly processed — no landfill, no shortcuts, no hazardous materials going to waste.</p>
          </div>
        </div>
      </div>
      <div class="mt-8 pt-6 border-t border-white/10">
        <p class="text-white/50 text-sm">
          Questions? Call us at <a href="tel:+14406019166" class="text-brand-green hover:underline">(440) 601-9166</a> or
          <a href="tel:+14406014153" class="text-brand-green hover:underline">(440) 601-4153</a>.
        </p>
      </div>
    </div>
  </section>

</BaseLayout>

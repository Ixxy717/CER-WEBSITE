---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import AcceptedItems from '../components/AcceptedItems.astro';
---

<BaseLayout
  title="Residential Drop-Off & Pickup"
  description="Free electronics drop-off in Chagrin Falls, OH. Free pickup for 12 or more items. See what we accept and how to schedule."
>

  <PageHero
    title="Residential Recycling"
    subtitle="Easy drop-off, free pickup, no hassle. We make getting rid of old electronics simple."
  />

  <!-- ── Drop-Off ────────────────────────────────────────── -->
  <section class="bg-section-white py-14 md:py-18">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">

        <div>
          <h2 class="text-2xl font-bold text-charcoal mb-4">Free Drop-Off</h2>
          <p class="text-charcoal/70 leading-relaxed mb-5">
            Bring your old electronics to our facility anytime during business hours.
            No appointment needed — just pull up and drop off. We'll take it from there.
          </p>
          <div class="bg-section-light rounded-xl p-6 flex flex-col gap-4 border border-black/5">
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-brand-green shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
              </svg>
              <div>
                <p class="font-semibold text-charcoal text-sm">Address</p>
                <p class="text-charcoal/65 text-sm">10140 Gottschalk Pkwy<br />Chagrin Falls, OH 44022</p>
              </div>
            </div>
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-brand-green shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
              </svg>
              <div>
                <p class="font-semibold text-charcoal text-sm">Phone</p>
                <a href="tel:+14406019166" class="text-charcoal/65 text-sm hover:text-brand-green transition-colors">(440) 601-9166</a>
                <span class="text-charcoal/40 text-sm"> · </span>
                <a href="tel:+14406014153" class="text-charcoal/65 text-sm hover:text-brand-green transition-colors">(440) 601-4153</a>
              </div>
            </div>
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-brand-green shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
              <div>
                <p class="font-semibold text-charcoal text-sm">Cost</p>
                <p class="text-charcoal/65 text-sm">Free — no appointment, no fees (TVs excluded)</p>
              </div>
            </div>
          </div>
        </div>

        <div>
          <h2 class="text-2xl font-bold text-charcoal mb-4">Free Pickup</h2>
          <p class="text-charcoal/70 leading-relaxed mb-5">
            Have a lot to get rid of? We'll come to you. Free pickup is available
            for <strong class="text-charcoal">12 or more items</strong>. Great for
            clearing out a home office, garage cleanout, or upgrading a whole household.
          </p>
          <div class="bg-section-light rounded-xl p-6 flex flex-col gap-4 border border-black/5">
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-brand-green shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
              </svg>
              <div>
                <p class="font-semibold text-charcoal text-sm">Minimum</p>
                <p class="text-charcoal/65 text-sm">12 or more items required for free pickup</p>
              </div>
            </div>
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-brand-green shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
              </svg>
              <div>
                <p class="font-semibold text-charcoal text-sm">How to schedule</p>
                <p class="text-charcoal/65 text-sm">Call or email us and we'll set up a time that works</p>
              </div>
            </div>
            <a
              href="/contact"
              class="mt-1 inline-block bg-brand-green text-charcoal font-semibold text-sm px-5 py-2.5 rounded-lg hover:brightness-110 transition-all w-fit"
            >
              Schedule a Pickup
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── TV Recycling note ──────────────────────────────── -->
  <section class="bg-charcoal text-white py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <p class="font-semibold text-white mb-1">Recycling a TV?</p>
          <p class="text-white/65 text-sm">
            TVs require a small fee of <strong class="text-white">$1 per diagonal inch</strong> due to hazardous materials.
            Pay online before you drop off or schedule pickup.
          </p>
        </div>
        <a
          href="/tv-recycling"
          class="shrink-0 inline-block bg-brand-green text-charcoal font-semibold text-sm px-5 py-2.5 rounded-lg hover:brightness-110 transition-all"
        >
          TV Recycling & Payment
        </a>
      </div>
    </div>
  </section>

  <!-- ── What We Accept ─────────────────────────────────── -->
  <section class="bg-section-light py-14 md:py-18">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <h2 class="text-2xl font-bold text-charcoal mb-3">What We Accept</h2>
        <p class="text-charcoal/65 max-w-xl">
          Bring items in as-is. No need to wipe drives, remove batteries, or prep anything — we handle all of that.
        </p>
      </div>
      <AcceptedItems showNote={true} />
    </div>
  </section>

  <!-- ── What happens to it ─────────────────────────────── -->
  <section class="bg-section-white py-14 md:py-18">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
      <h2 class="text-2xl font-bold text-charcoal mb-4">What Happens to Your Electronics</h2>
      <div class="flex flex-col gap-5">
        <div class="flex gap-4">
          <div class="w-8 h-8 rounded-full bg-brand-green/15 flex items-center justify-center shrink-0 mt-0.5">
            <span class="text-brand-green font-bold text-sm">1</span>
          </div>
          <div>
            <p class="font-semibold text-charcoal mb-1">Sorted by hand</p>
            <p class="text-charcoal/65 text-sm leading-relaxed">Everything that comes in gets looked at individually. We check condition and figure out the best path for each item.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="w-8 h-8 rounded-full bg-brand-green/15 flex items-center justify-center shrink-0 mt-0.5">
            <span class="text-brand-green font-bold text-sm">2</span>
          </div>
          <div>
            <p class="font-semibold text-charcoal mb-1">Reused or refurbished when possible</p>
            <p class="text-charcoal/65 text-sm leading-relaxed">Items or parts that still have life in them get repaired, refurbished, or passed along for reuse. The best outcome for the environment — and for someone who can use it.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="w-8 h-8 rounded-full bg-brand-green/15 flex items-center justify-center shrink-0 mt-0.5">
            <span class="text-brand-green font-bold text-sm">3</span>
          </div>
          <div>
            <p class="font-semibold text-charcoal mb-1">Responsibly recycled</p>
            <p class="text-charcoal/65 text-sm leading-relaxed">Whatever can't be reused goes to a certified end-of-life facility for proper material recovery. Not a landfill.</p>
          </div>
        </div>
      </div>
      </div>
    </div>
  </section>

</BaseLayout>

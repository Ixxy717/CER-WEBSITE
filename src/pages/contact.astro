---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import MapEmbed from '../components/MapEmbed.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contact"
  description="Contact Chagrin Electronic Recycling. Drop off electronics at 10140 Gottschalk Pkwy, Chagrin Falls, OH. Call (440) 601-9166 or send a message."
>

  <PageHero
    title="Contact Us"
    subtitle="Questions about drop-off, pickup, or TV recycling? We're easy to reach."
  />

  <!-- ── Main contact section ──────────────────────────────── -->
  <section class="bg-section-white py-14 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

        <!-- Left: info + map -->
        <div class="flex flex-col gap-8">

          <!-- Contact details -->
          <div class="flex flex-col gap-5">
            <h2 class="text-xl font-bold text-charcoal">Get in Touch</h2>

            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-lg bg-brand-green/15 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-brand-green" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-charcoal mb-1">Address</p>
                <address class="not-italic text-sm text-charcoal/65 leading-relaxed">
                  10140 Gottschalk Pkwy<br />
                  Chagrin Falls, OH 44022
                </address>
                <p class="text-xs text-brand-green mt-1 font-medium">Free drop-off — no appointment needed</p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-lg bg-brand-green/15 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-brand-green" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-charcoal mb-1">Phone</p>
                <div class="flex flex-col gap-1">
                  <a href="tel:+14406019166" class="text-sm text-charcoal/65 hover:text-brand-green transition-colors">(440) 601-9166</a>
                  <a href="tel:+14406014153" class="text-sm text-charcoal/65 hover:text-brand-green transition-colors">(440) 601-4153</a>
                </div>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-lg bg-brand-green/15 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-brand-green" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-charcoal mb-1">Email</p>
                <a
                  href="mailto:Chagrin-E-Recycling@scarce-resources.com"
                  class="text-sm text-charcoal/65 hover:text-brand-green transition-colors break-all"
                >
                  Chagrin-E-Recycling@scarce-resources.com
                </a>
              </div>
            </div>
          </div>

          <!-- Map -->
          <MapEmbed class="h-72 md:h-80" />

        </div>

        <!-- Right: form -->
        <div>
          <h2 class="text-xl font-bold text-charcoal mb-6">Send a Message</h2>
          <ContactForm />
          <p class="mt-5 text-xs text-charcoal/40 leading-relaxed">
            For bulk or business electronics recovery, contact our sister company
            <a href="https://scarce-resources.com" target="_blank" rel="noopener noreferrer" class="text-brand-green hover:underline">Scarce Resources Company Inc.</a>
          </p>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

---
import BaseLayout from './BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  lastUpdated: string;
}

const { title, subtitle, description, lastUpdated } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <PageHero title={title} subtitle={subtitle} />

  <section class="bg-section-white py-14 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-sm text-charcoal/50 mb-8">Last updated: {lastUpdated}</p>

      <div
        class="prose prose-neutral max-w-none
               prose-headings:text-charcoal prose-headings:font-bold
               prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
               prose-h3:text-lg prose-h3:mt-6 prose-h3:mb-2
               prose-p:text-charcoal/75 prose-p:leading-relaxed
               prose-li:text-charcoal/75 prose-li:marker:text-brand-green
               prose-strong:text-charcoal
               prose-a:text-brand-green prose-a:font-medium hover:prose-a:underline"
      >
        <slot />
      </div>
    </div>
  </section>
</BaseLayout>
